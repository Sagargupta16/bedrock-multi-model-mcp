{
  "name": "bedrock-multi-model-mcp",
  "version": "0.2.0",
  "description": "MCP server for invoking any AWS Bedrock model via the unified Converse API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bedrock-multi-model-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "aws",
    "bedrock",
    "llama",
    "mistral",
    "nova",
    "cohere",
    "deepseek",
    "multi-model",
    "converse-api"
  ],
  "author": "Sagar Gupta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sagargupta16/bedrock-multi-model-mcp.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.1030.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1030.0",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3"
  }
}
